{
  "name": "@conan-scott/openclaw-fish-audio",
  "version": "1.0.0",
  "description": "Fish Audio TTS speech provider plugin for OpenClaw — high-quality voice cloning and text-to-speech",
  "type": "module",
  "license": "MIT",
  "author": "Conan Scott",
  "repository": {
    "type": "git",
    "url": "https://github.com/Conan-Scott/openclaw-fish-audio.git"
  },
  "homepage": "https://github.com/Conan-Scott/openclaw-fish-audio#readme",
  "bugs": {
    "url": "https://github.com/Conan-Scott/openclaw-fish-audio/issues"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "fish-audio",
    "tts",
    "text-to-speech",
    "voice-cloning",
    "speech-provider"
  ],
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.31"
    }
  },
  "files": [
    "index.ts",
    "speech-provider.ts",
    "tts.ts",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "devDependencies": {
    "vitest": "^3.1.0"
  }
}
