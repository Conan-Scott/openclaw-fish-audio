{
  "name": "@conan-scott/openclaw-fish-audio",
  "version": "1.1.0",
  "description": "Fish Audio speech provider for OpenClaw with high-quality TTS, voice cloning, configurable voices, and voice-note friendly output for Telegram and WhatsApp.",
  "type": "module",
  "license": "MIT",
  "author": "Conan Scott",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Conan-Scott/openclaw-fish-audio.git"
  },
  "homepage": "https://github.com/Conan-Scott/openclaw-fish-audio#readme",
  "bugs": {
    "url": "https://github.com/Conan-Scott/openclaw-fish-audio/issues"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "openclaw tts",
    "fish-audio",
    "fish-audio-tts",
    "tts",
    "text-to-speech",
    "speech",
    "speech-provider",
    "voice",
    "voice-cloning",
    "voice-notes",
    "telegram tts",
    "telegram voice",
    "whatsapp tts",
    "whatsapp voice",
    "ai voice",
    "cloned voice"
  ],
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.31"
    },
    "build": {
      "openclawVersion": "2026.4.27",
      "pluginSdkVersion": "2026.4.27"
    }
  },
  "files": [
    "index.ts",
    "speech-provider.ts",
    "tts.ts",
    "openclaw.plugin.json",
    "skills",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "devDependencies": {
    "openclaw": "^2026.4.27",
    "vitest": "^3.1.0"
  },
  "scripts": {
    "test": "vitest run"
  }
}
